{
  "name": "@authbound/pension-credential",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @authbound/server build",
    "dev": "tsx --env-file-if-exists=.env.local server.ts",
    "pretypecheck": "pnpm --filter @authbound/server build",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions --module NodeNext --moduleResolution NodeNext --target ES2022 --types node server.ts"
  },
  "dependencies": {
    "@authbound/server": "workspace:*",
    "express": "^5.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "24.10.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.6",
    "typescript": "5.9.2"
  }
}
