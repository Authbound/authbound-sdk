# Secret API key (sk_test_* or sk_live_*)
AUTHBOUND_SECRET_KEY=sk_test_your_key_here

# Publishable key — required for browser-safe verification status polling
AUTHBOUND_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: point at local gateway instead of production API
# AUTHBOUND_API_URL=http://127.0.0.1:3001

# Optional
# PORT=3333
# AUTHBOUND_DEBUG=true
