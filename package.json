{
  "name": "@authbound",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm -r --filter './packages/*' run dev",
    "lint": "biome check --config-path ./biome.json .",
    "format": "biome check --config-path ./biome.json --write .",
    "check-types": "pnpm -r --filter './packages/*' run typecheck",
    "release:check": "pnpm lint && pnpm check-types && pnpm test && pnpm build && pnpm validate:artifacts",
    "test": "pnpm -r --filter './packages/*' run test",
    "validate:artifacts": "node scripts/validate-package-artifacts.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "catalog:",
    "changesets": "^1.0.2",
    "tsup": "catalog:",
    "turbo": "^2.7.3",
    "typescript": "catalog:",
    "ultracite": "^6.3.2",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
