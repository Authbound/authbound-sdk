{
  "name": "@authbound/nuxt",
  "version": "0.1.0",
  "description": "Authbound Nuxt 3 module - Complete verification for Nuxt with auto-imports and server middleware.",
  "type": "module",
  "license": "MIT",
  "author": "Authbound",
  "homepage": "https://github.com/authbound/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/authbound/sdk.git",
    "directory": "packages/nuxt"
  },
  "bugs": {
    "url": "https://github.com/authbound/sdk/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/module.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@authbound/core": "workspace:*",
    "@authbound/server": "workspace:*",
    "@authbound/vue": "workspace:*",
    "@nuxt/kit": "^3.17.4",
    "h3": "^1.15.4"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.17.4",
    "nuxt": "^3.17.4",
    "sass": "^1.92.1",
    "typescript": "5.9.2",
    "unbuild": "^3.5.0",
    "vitest": "4.0.8",
    "vue": "3.5.26"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "prepack": "nuxt-module-build build",
    "test": "vitest run src --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
