{
  "name": "@authbound/react",
  "version": "0.1.0",
  "description": "Authbound React 18 bindings (hooks + headless components) for verification flows.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Authbound",
  "homepage": "https://github.com/authbound/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/authbound/sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/authbound/sdk/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18.3.0 <20",
    "react-dom": ">=18.3.0 <20"
  },
  "dependencies": {
    "@authbound/core": "workspace:*",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "tsup": "8.5.0",
    "typescript": "5.9.2",
    "vitest": "4.0.8",
    "@testing-library/react": "16.3.0"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/testing.tsx --dts --format esm,cjs --clean --no-config && cp src/styles/variables.css dist/styles.css",
    "dev": "tsup src/index.tsx src/testing.tsx --dts --format esm,cjs --watch --no-config",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "ultracite lint",
    "format": "ultracite format"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
